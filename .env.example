# Gemini API key (required). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override Gemini models (defaults: gemini-2.5-flash)
# GEMINI_VALIDATION_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash

# Postgres for lead form storage (required for saving leads). Set automatically if you add Neon from Vercel Marketplace.
# DATABASE_URL=postgresql://...
